# ansible-lint configuration
# https://ansible.readthedocs.io/projects/lint/configuring/

exclude_paths:
  - .venv/
  - collections/

# Warn only (don't fail) on these rules
warn_list:
  - yaml[line-length]
  - name[casing]

# Skip these rules entirely
skip_list:
  - role-name           # local role names don't need galaxy naming
  - var-naming          # existing var names are intentional (cross-role shared vars)
  - name[missing]       # import_tasks without names is valid style
